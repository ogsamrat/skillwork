# Worker Agent Configuration
# Copy to .env and fill in values

# Groq API key for LLM-powered research/stats handlers
GROQ_API_KEY=...

# Wallet address to receive payments (each worker can have its own)
WALLET_ADDRESS=0xYourWalletAddress...

# These are set per-worker via npm scripts, but can be overridden:
# PORT=4021
# AGENT_TYPE=research
# AGENT_NAME=ResearchAgent1
